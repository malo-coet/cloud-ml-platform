# Copy to .env and adjust if needed — the defaults below already work for local dev.
# NEVER commit the real .env file.

POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops-dev-password
POSTGRES_DB=mlplatform

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Auth — generate a strong value outside local dev, e.g. `openssl rand -hex 32`
JWT_SECRET_KEY=dev-secret-change-me
